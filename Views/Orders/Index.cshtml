@model IReadOnlyList<Order>
@{
    ViewData["Title"] = "My orders";
}

<section class="card content-card">
    <h1>My orders</h1>

    @if (Model.Count == 0)
    {
        <p>No orders yet.</p>
        <a class="btn btn-primary" asp-controller="Catalog" asp-action="Index">Start shopping</a>
    }
    else
    {
        <div class="table-wrap">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Order</th>
                        <th>Date</th>
                        <th>Total</th>
                        <th>Payment</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td>@order.OrderNumber</td>
                        <td>@order.OrderedAtUtc.ToLocalTime().ToString("dd MMM yyyy")</td>
                        <td>@order.Total.ToString("C")</td>
                        <td><span class="badge">@order.PaymentStatus</span></td>
                        <td>@order.OrderStatus</td>
                        <td><a class="text-link" asp-controller="Orders" asp-action="Details" asp-route-orderNumber="@order.OrderNumber">Details</a></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>

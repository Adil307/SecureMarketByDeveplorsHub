@model RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<section class="auth-card card">
    <h1>Create account</h1>
    <form asp-controller="Auth" asp-action="Register" method="post">
        <div asp-validation-summary="ModelOnly" class="validation"></div>

        <label>
            <span>Full name</span>
            <input asp-for="FullName" autocomplete="name" />
            <span asp-validation-for="FullName"></span>
        </label>

        <label>
            <span>Email</span>
            <input asp-for="Email" autocomplete="email" />
            <span asp-validation-for="Email"></span>
        </label>

        <label>
            <span>Password</span>
            <input asp-for="Password" autocomplete="new-password" />
            <span asp-validation-for="Password"></span>
        </label>

        <label>
            <span>Confirm password</span>
            <input asp-for="ConfirmPassword" autocomplete="new-password" />
            <span asp-validation-for="ConfirmPassword"></span>
        </label>

        <button class="btn btn-primary btn-block" type="submit">Register</button>
        <p class="auth-switch">Already registered? <a asp-controller="Auth" asp-action="Login">Login</a></p>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@model CartViewModel
@{
    ViewData["Title"] = "Shopping cart";
}

<section class="cart-layout">
    <div class="cart-main card">
        <div class="cart-title-row">
            <h1>My cart (@Model.Count)</h1>
        </div>

        @if (Model.Items.Count == 0)
        {
            <div class="empty-state">
                <h2>Your cart is empty</h2>
                <p>Browse products and add items to your cart.</p>
                <a class="btn btn-primary" asp-controller="Catalog" asp-action="Index">Browse catalog</a>
            </div>
        }
        else
        {
            @foreach (var item in Model.Items)
            {
                <article class="cart-item">
                    <img src="@item.Product?.ImageUrl" alt="@item.Product?.Name" />

                    <div class="cart-item__body">
                        <h2>@item.Product?.Name</h2>
                        <p class="muted">Size: medium, Color: blue, &nbsp; Material: Plastic</p>
                        <p class="muted">Seller: @item.Product?.Seller</p>

                        <div class="cart-actions">
                            <form asp-controller="Cart" asp-action="Remove" method="post">
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <button class="btn btn-outline-danger btn-sm" type="submit">Remove</button>
                            </form>

                            <button class="btn btn-outline btn-sm" type="button">Save for later</button>
                        </div>
                    </div>

                    <div class="cart-item__side">
                        <strong>@(((item.Product?.Price ?? 0) * item.Quantity).ToString("C"))</strong>

                        <form asp-controller="Cart" asp-action="Update" method="post" class="quantity-form">
                            <input type="hidden" name="productId" value="@item.ProductId" />

                            <select name="quantity" onchange="this.form.submit()">
                                @for (var q = 1; q <= 10; q++)
                                {
                                    <option value="@q" selected="@(item.Quantity == q ? "selected" : null)">Qty: @q</option>
                                }
                            </select>
                        </form>
                    </div>
                </article>
            }

            <div class="cart-bottom-actions">
                <a class="btn btn-primary cart-back-btn" asp-controller="Catalog" asp-action="Index">
                    <span>←</span>
                    Back to shop
                </a>

                <form asp-controller="Cart" asp-action="Clear" method="post">
                    <button class="btn btn-outline" type="submit">Remove all</button>
                </form>
            </div>
        }
    </div>

    <aside class="cart-summary">
        <div class="card coupon-card">
            <label for="coupon">Have a coupon?</label>
            <div class="coupon-row">
                <input id="coupon" placeholder="Add coupon" />
                <button type="button">Apply</button>
            </div>
        </div>

        <div class="card summary-card">
            <dl>
                <dt>Subtotal:</dt>
                <dd>@Model.SubTotal.ToString("C")</dd>

                <dt>Discount:</dt>
                <dd class="red-text">- $0.00</dd>

                <dt>Tax:</dt>
                <dd class="green-text">+ @Model.Tax.ToString("C")</dd>

                @if (Model.Shipping > 0)
                {
                    <dt>Shipping:</dt>
                    <dd>@Model.Shipping.ToString("C")</dd>
                }

                <dt class="total">Total:</dt>
                <dd class="total">@Model.Total.ToString("C")</dd>
            </dl>

            <a class="btn btn-success btn-block @(Model.Items.Count == 0 ? "disabled" : "")"
               asp-controller="Checkout"
               asp-action="Index">
                Checkout
            </a>

            <div class="payment-icons">
                <span>AMEX</span>
                <span>MC</span>
                <span>PayPal</span>
                <span>VISA</span>
                <span>Pay</span>
            </div>
        </div>
    </aside>
</section>

@if (Model.Items.Count > 0)
{
    <section class="cart-perks">
        <div class="cart-perk">
            <span class="perk-icon">
    <svg width="16" height="21" viewBox="0 0 16 21" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path fill-rule="evenodd" clip-rule="evenodd" d="M14 7H13V5C13 2.24 10.76 0 8 0C5.24 0 3 2.24 3 5V7H2C0.9 7 0 7.9 0 9V19C0 20.1 0.9 21 2 21H14C15.1 21 16 20.1 16 19V9C16 7.9 15.1 7 14 7ZM8 16C6.9 16 6 15.1 6 14C6 12.9 6.9 12 8 12C9.1 12 10 12.9 10 14C10 15.1 9.1 16 8 16ZM5 7V5C5 3.34 6.34 2 8 2C9.66 2 11 3.34 11 5V7H5Z" fill="#8B96A5"/>
    </svg>
</span>
            <p>
                <strong>Secure payment</strong>
                <small>Have you ever finally just</small>
            </p>
        </div>

        <div class="cart-perk">
           <span class="perk-icon">
    <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="24" cy="24" r="24" fill="#DEE2E7"/>
        <path fill-rule="evenodd" clip-rule="evenodd" d="M32 15H16C14.9 15 14.01 15.9 14.01 17L14 35L18 31H32C33.1 31 34 30.1 34 29V17C34 15.9 33.1 15 32 15ZM19 22H29C29.55 22 30 22.45 30 23C30 23.55 29.55 24 29 24H19C18.45 24 18 23.55 18 23C18 22.45 18.45 22 19 22ZM25 27H19C18.45 27 18 26.55 18 26C18 25.45 18.45 25 19 25H25C25.55 25 26 25.45 26 26C26 26.55 25.55 27 25 27ZM29 21H19C18.45 21 18 20.55 18 20C18 19.45 18.45 19 19 19H29C29.55 19 30 19.45 30 20C30 20.55 29.55 21 29 21Z" fill="#8B96A5"/>
    </svg>
</span>
            <p>
                <strong>Customer support</strong>
                <small>Have you ever finally just</small>
            </p>
        </div>

        <div class="cart-perk">
          <span class="perk-icon">
    <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="24" cy="24" r="24" fill="#DEE2E7"/>
        <path fill-rule="evenodd" clip-rule="evenodd" d="M31.5 20H29V18C29 16.9 28.1 16 27 16H15C13.9 16 13 16.9 13 18V27C13 28.1 13.9 29 15 29C15 30.66 16.34 32 18 32C19.66 32 21 30.66 21 29H27C27 30.66 28.34 32 30 32C31.66 32 33 30.66 33 29H34C34.55 29 35 28.55 35 28V24.67C35 24.24 34.86 23.82 34.6 23.47L32.3 20.4C32.11 20.15 31.81 20 31.5 20ZM18 30C17.45 30 17 29.55 17 29C17 28.45 17.45 28 18 28C18.55 28 19 28.45 19 29C19 29.55 18.55 30 18 30ZM31.5 21.5L33.46 24H29V21.5H31.5ZM30 30C29.45 30 29 29.55 29 29C29 28.45 29.45 28 30 28C30.55 28 31 28.45 31 29C31 29.55 30.55 30 30 30Z" fill="#8B96A5"/>
    </svg>
</span>
            <p>
                <strong>Free delivery</strong>
                <small>Have you ever finally just</small>
            </p>
        </div>
    </section>

    <section class="saved-section card">
        <h2>Saved for later</h2>

        <div class="saved-grid">
            @foreach (var item in Model.Items.Take(4))
            {
                var savedProduct = item.Product;

                if (savedProduct is not null)
                {
                    <article class="saved-card">
                        <a asp-controller="Catalog" asp-action="Details" asp-route-slug="@savedProduct.Slug">
                            <div class="saved-card__image">
                                <img src="@savedProduct.ImageUrl" alt="@savedProduct.Name" />
                            </div>
                        </a>

                        <strong>@savedProduct.Price.ToString("C")</strong>

                        <a class="saved-card__title"
                           asp-controller="Catalog"
                           asp-action="Details"
                           asp-route-slug="@savedProduct.Slug">
                            @savedProduct.Name
                        </a>

                        <form asp-controller="Cart" asp-action="Add" method="post">
                            <input type="hidden" name="productId" value="@savedProduct.Id" />
                            <input type="hidden" name="quantity" value="1" />
                           <button class="btn btn-outline btn-sm move-cart-btn" type="submit">
    <svg width="19" height="19" viewBox="0 0 19 19" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M13.3375 10.0833C14.025 10.0833 14.63 9.7075 14.9417 9.13917L18.2233 3.19C18.5625 2.585 18.1225 1.83333 17.4258 1.83333H3.85917L2.9975 0H0V1.83333H1.83333L5.13333 8.79083L3.89583 11.0275C3.22667 12.2558 4.10667 13.75 5.5 13.75H16.5V11.9167H5.5L6.50833 10.0833H13.3375ZM4.73 3.66667H15.8675L13.3375 8.25H6.9025L4.73 3.66667ZM5.5 14.6667C4.49167 14.6667 3.67583 15.4917 3.67583 16.5C3.67583 17.5083 4.49167 18.3333 5.5 18.3333C6.50833 18.3333 7.33333 17.5083 7.33333 16.5C7.33333 15.4917 6.50833 14.6667 5.5 14.6667ZM14.6667 14.6667C13.6583 14.6667 12.8425 15.4917 12.8425 16.5C12.8425 17.5083 13.6583 18.3333 14.6667 18.3333C15.675 18.3333 16.5 17.5083 16.5 16.5C16.5 15.4917 15.675 14.6667 14.6667 14.6667Z" fill="#0D6EFD"/>
    </svg>
    Move to cart
</button>
                        </form>
                    </article>
                }
            }
        </div>
    </section>
}

<section class="discount-banner">
    <div>
        <h2>Super discount on more than 100 USD</h2>
        <p>Have you ever finally just write dummy info</p>
    </div>
    <a class="btn btn-warning" asp-controller="Catalog" asp-action="Index">Shop now</a>
</section>
@model HomeIndexViewModel

@{
    ViewData["Title"] = "Home";
}

<section class="home-grid">
    <aside class="category-menu card">
        <a asp-controller="Catalog" asp-action="Index">Automobiles</a>
        <a asp-controller="Catalog" asp-action="Index" asp-route-category="clothes-wear">Clothes and wear</a>
        <a asp-controller="Catalog" asp-action="Index" asp-route-category="home-outdoor">Home interiors</a>
        <a asp-controller="Catalog" asp-action="Index" asp-route-category="consumer-electronics">Computer and tech</a>
        <a asp-controller="Catalog" asp-action="Index" asp-route-category="machinery-tools">Tools, equipments</a>
        <a asp-controller="Catalog" asp-action="Index" asp-route-category="sports-outdoor">Sports and outdoor</a>
        <a asp-controller="Catalog" asp-action="Index" asp-route-category="animal-pets">Animal and pets</a>
        <a asp-controller="Catalog" asp-action="Index" asp-route-category="machinery-tools">Machinery tools</a>
        <a asp-controller="Catalog" asp-action="Index">More category</a>
    </aside>

    <div class="hero-card">
        <div class="hero-copy">
            <p>Latest trending</p>
            <h1>Electronic items</h1>
            <a class="btn btn-light" asp-controller="Catalog" asp-action="Index" asp-route-category="consumer-electronics">Learn more</a>
        </div>
        <button class="mobile-menu-btn" type="button" aria-label="Open menu">
    <span></span>
</button>
        <img src="~/img/banners/hero-electronics.png" asp-append-version="true" alt="Electronic items banner" />
    </div>

    <aside class="buyer-card card">
        <div class="buyer-card__user">
            <span class="avatar">U</span>
            <p>Hi, user<br /><strong>let's get started</strong></p>
        </div>

        @if (User.Identity?.IsAuthenticated == true)
        {
            <a class="btn btn-primary btn-block" asp-controller="Orders" asp-action="Index">My orders</a>
        }
        else
        {
            <a class="btn btn-primary btn-block" asp-controller="Auth" asp-action="Register">Join now</a>
            <a class="btn btn-outline btn-block" asp-controller="Auth" asp-action="Login">Log in</a>
        }

        <div class="promo orange">Get US $10 off with a new supplier</div>
        <div class="promo teal">Send quotes with supplier preferences</div>
    </aside>
</section>

<section class="card deals-row">
    <div class="deals-row__title">
        <h2>Deals and offers</h2>
        <p>Hygiene equipments</p>

        <div class="timer">
            <span><strong>04</strong><small>Days</small></span>
            <span><strong>13</strong><small>Hour</small></span>
            <span><strong>34</strong><small>Min</small></span>
            <span><strong>56</strong><small>Sec</small></span>
        </div>
    </div>

    <a class="deal-item" asp-controller="Catalog" asp-action="Index">
        <img src="~/img/products/smartwatch-silver.png" asp-append-version="true" alt="Smart watches" />
        <strong>Smart watches</strong>
        <span>-25%</span>
    </a>

    <a class="deal-item" asp-controller="Catalog" asp-action="Index">
        <img src="~/img/products/laptop.png" asp-append-version="true" alt="Laptops" />
        <strong>Laptops</strong>
        <span>-15%</span>
    </a>

    <a class="deal-item" asp-controller="Catalog" asp-action="Index">
        <img src="~/img/products/camera.png" asp-append-version="true" alt="GoPro cameras" />
        <strong>GoPro cameras</strong>
        <span>-40%</span>
    </a>

    <a class="deal-item" asp-controller="Catalog" asp-action="Index">
        <img src="~/img/products/headphones-white.png" asp-append-version="true" alt="Headphones" />
        <strong>Headphones</strong>
        <span>-25%</span>
    </a>

    <a class="deal-item" asp-controller="Catalog" asp-action="Index">
        <img src="~/img/products/camera.png" asp-append-version="true" alt="Canon cameras" />
        <strong>Canon cameras</strong>
        <span>-25%</span>
    </a>
</section>

<section class="source-section">
   <div class="source-banner home-outdoor">
    <h2>Home and outdoor</h2>
    <a class="btn btn-light"
       asp-controller="Catalog"
       asp-action="Index"
       asp-route-category="home-outdoor">
        Source now
    </a>
</div>

    <div class="source-products">
        @foreach (var product in Model.HomeOutdoor.Take(8))
        {
            <a class="source-product" asp-controller="Catalog" asp-action="Details" asp-route-slug="@product.Slug">
                <span>@product.Name</span>
                <small>From USD @product.Price.ToString("0")</small>
                <img src="@product.ImageUrl" alt="@product.Name" />
            </a>
        }
    </div>
</section>

<section class="source-section">
  <div class="source-banner electronics">
    <h2>Consumer electronics and gadgets</h2>
    <a class="btn btn-light"
       asp-controller="Catalog"
       asp-action="Index"
       asp-route-category="consumer-electronics">
        Source now
    </a>
</div>

    <div class="source-products">
        @foreach (var product in Model.Electronics.Take(8))
        {
            <a class="source-product" asp-controller="Catalog" asp-action="Details" asp-route-slug="@product.Slug">
                <span>@product.Name</span>
                <small>From USD @product.Price.ToString("0")</small>
                <img src="@product.ImageUrl" alt="@product.Name" />
            </a>
        }
    </div>
</section>

<section class="request-banner">
    <div>
        <h2>An easy way to send requests to all suppliers</h2>
        <p>Send one request and get quotes from verified suppliers.</p>
    </div>

    <form class="request-card" method="get" asp-controller="Catalog" asp-action="Index">
        <h3>Send quote to suppliers</h3>
        <input name="q" placeholder="What item you need?" />
        <textarea name="details" placeholder="Type more details"></textarea>

        <div class="form-row">
            <input name="qty" type="number" placeholder="Qty" min="1" />
            <select name="unit">
                <option>Pcs</option>
                <option>Box</option>
            </select>
        </div>

        <button class="btn btn-primary" type="submit">Send inquiry</button>
    </form>
</section>

<section class="section-heading">
    <h2>Recommended items</h2>
</section>

<section class="product-grid">
    @foreach (var product in Model.Recommended)
    {
        <partial name="_ProductCard" model="product" />
    }
</section>

<section class="section-heading extra-services-heading">
    <h2>Our extra services</h2>
</section>

<section class="section-heading extra-services-heading">
    <h2>Our extra services</h2>
</section>

